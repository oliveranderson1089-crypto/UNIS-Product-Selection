# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — never commit real keys.

# ===== DeepSeek (primary text LLM) =====
# Get key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== Claude (vision now, text later) =====
# Get key at: https://console.anthropic.com/settings/keys
# Leave blank to disable image input.
ANTHROPIC_API_KEY=

# ===== Crawler =====
# Polite delay between page fetches (seconds)
CRAWLER_DELAY=1.5
CRAWLER_USER_AGENT=UNIS-Product-Selection/0.1 (educational; +https://example.com/contact)

# ===== Storage paths (override config.yaml if needed) =====
# DATA_DIR=data
